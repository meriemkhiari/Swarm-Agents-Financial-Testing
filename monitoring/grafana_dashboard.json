{
  "title": "Swarm Fraud Detection",
  "uid": "swarm-fraud-detection",
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gateway_request_count[1m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency p50/p95/p99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fraud Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "gateway_fraud_rate",
          "legendFormat": "fraud_rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent" }
      }
    },
    {
      "id": 4,
      "title": "Per-Agent Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(agent_score_bucket[5m])) by (agent_id, le)",
          "legendFormat": "{{agent_id}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis Pub/Sub Message Lag (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(redis_pubsub_lag_ms_bucket[5m])) by (le))",
          "legendFormat": "p95 lag"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active Agent Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "count(up{job=~\"agent_.*\"} == 1)",
          "legendFormat": "active_agents"
        }
      ]
    }
  ]
}