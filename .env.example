
# OLLAMA Configuration
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# For local testing, you can set OLLAMA_BASE_URL=http://localhost:11434/v1

# Redis Configuration
REDIS_URL=redis://redis:6379/0
TX_EVENTS_CHANNEL=tx_events
AGENT_SCORES_CHANNEL=agent_scores
DECISIONS_CHANNEL=decisions

# Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Agent Thresholds
THRESHOLD_AGENT_AMOUNT=0.65
THRESHOLD_AGENT_FREQUENCY=0.70
THRESHOLD_AGENT_GEOLOCATION=0.80
THRESHOLD_AGENT_DEVICE=0.75

# Data Path
PAYSIM_CSV_PATH=/data/paysim.csv

# Collection Timeout
COLLECTION_TIMEOUT_SECONDS=2.0

# Grafana Admin Password
GRAFANA_ADMIN_PASSWORD=admin
